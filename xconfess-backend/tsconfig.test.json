{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "paths": {
      "src/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.spec.ts", "test/**/*.ts"]
}
