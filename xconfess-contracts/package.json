{
  "name": "xconfess-contracts",
  "version": "0.0.1",
  "private": true,
  "description": "NPM shim for building/testing xconfess Soroban contracts from the monorepo root.",
  "scripts": {
    "build": "cargo build --workspace --target wasm32-unknown-unknown",
    "build:release": "cargo build --workspace --release --target wasm32-unknown-unknown",
    "test": "cargo test --workspace",
    "test:integration": "cargo test --workspace",
    "contract:test:integration": "cargo test --test integration -p confession-anchor -- --nocapture",
    "lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "fmt": "cargo fmt --all",
    "fmt:check": "cargo fmt --all -- --check",
    "clean": "cargo clean --workspace",
    "deploy:testnet": "cd .. && ./scripts/contracts-release.sh deploy --network testnet --source deployer",
    "optimize": "stellar contract optimize --wasm target/wasm32-unknown-unknown/release/confession_anchor.wasm",
    "test:verbose": "cargo test --workspace -- --nocapture",
    "test:coverage": "echo \"Install cargo-tarpaulin to run coverage (e.g. cargo install cargo-tarpaulin).\""
  },
  "engines": {
    "node": ">=18"
  }
}

